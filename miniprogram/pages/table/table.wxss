/* ========================================
   表格浏览页样式
   ======================================== */

.page-table {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

/* Sheet 标签栏 */
.sheet-tabs {
  display: flex;
  white-space: nowrap;
  padding: 16rpx;
  background: var(--card-bg);
  border-bottom: 2rpx solid #f0f0f0;
  flex-shrink: 0;
}

.sheet-tab {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-right: 12rpx;
  flex-shrink: 0;
  background: var(--card-bg);
}

.sheet-tab.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  font-weight: 600;
}

.sheet-count {
  font-size: 20rpx;
  opacity: 0.6;
}

/* 表格容器 */
.table-scroll-x {
  flex: 1;
  overflow: auto;
}

.table-wrap {
  min-width: 100%;
}

/* 表头 */
.table-header {
  display: flex;
  background: #f1f5f9;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 2rpx solid #cbd5e1;
}

.th {
  padding: 12rpx 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #334155;
  text-align: center;
  border-right: 1rpx solid #e2e8f0;
  line-height: 1.4;
  box-sizing: border-box;
}

.th:last-child {
  border-right: none;
}

/* 表体 */
.table-body {
  background: var(--card-bg);
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f1f5f9;
}

.table-row:active {
  background: #f8fafc;
}

.td {
  padding: 10rpx 8rpx;
  font-size: 22rpx;
  color: var(--text);
  border-right: 1rpx solid #f5f5f5;
  line-height: 1.5;
  word-break: break-all;
  box-sizing: border-box;
}

.td:last-child {
  border-right: none;
}

.td-price {
  font-weight: 700;
  color: #d97706;
  background: #fffbeb;
  text-align: right;
}

.td-weikai {
  font-size: 20rpx;
  color: #1e40af;
  background: #eff6ff;
}

/* 表格信息 */
.table-info {
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  background: var(--card-bg);
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
