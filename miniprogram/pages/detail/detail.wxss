/* ========================================
   详情页样式
   ======================================== */

.page-detail {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 名称区 */
.detail-name {
  padding: 28rpx;
}

.detail-sheet {
  margin-bottom: 12rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.5;
  display: block;
}

/* 基本信息 */
.detail-info {
  padding: 0;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--text);
  flex: 1;
  line-height: 1.5;
}

.info-price {
  font-weight: 700;
  color: #d97706;
}

/* 详细内容区 */
.detail-section {
  padding: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}
